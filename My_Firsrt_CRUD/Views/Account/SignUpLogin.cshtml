@model ViewModel_LoginUser
@{
    Layout = null;
    string returnUrl = ViewBag.ReturnUrl;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>ورود و ثبت نام</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/My_Firsrt_CRUD.styles.css" asp-append-version="true" />
</head>

<body style="direction:rtl; margin:20px">

    <div class="container">

        

        <div class="row">
            <!-- نمایش کلیه خطاهای اعتبارسنجی ثبت نام و لاگین در بالای فرم ها -->
            <div class="col-md-12">
                <div asp-validation-summary="All" class="text-danger"></div>
            </div>

            <!-- فرم سمت راست -->
            <div class="col-md-6">
                <div class="panel panel-default">

                    <div class="panel-heading">
                        <br/>
                        <h3 class="panel-title">ثبت نام</h3>
                        <br/>
                    </div>

                    <div class="panel-body">
                        @*فرم ثبت نام*@
                        <form asp-controller="Account" asp-action="SignUp" method="post">
                            <br/>

                            <div class="form-group">
                                @Html.Label("نام کاربری") 
                                <input type="text" name="UserName" class="form-control" required />
                            </div>

                            <br/>

                            <div class="form-group">
                                @Html.Label("ایمیل") 
                                <input type="text" name="Email" class="form-control" required />
                            </div>

                            <br/>

                            <div class="form-group">
                                @Html.Label("شماره تلفن") 
                                <input type="text" name="Phone" class="form-control" required />
                            </div>

                            <br/>

                            <div class="form-group">
                                @Html.Label("رمز عبور") <br/>
                                <input type="password" name="Password" class="form-control" required />
                            </div>

                            <br/>
                            @*returnUrl ارسال*@
                            <input type="hidden" asp-for="@returnUrl" />

                            <button type="submit" class="btn btn-primary">ثبت نام</button>
                        </form>
                    </div>

                </div>
            </div>

            <!-- فرم سمت چپ -->
            <div class="col-md-6">
                <div class="panel panel-default">
                    
                    <div class="panel-heading">
                        <br/>
                        <h3 class="panel-title">ورود</h3>
                        <br/>
                    </div>
                    
                    <div class="panel-body">
                        @*فرم ورود*@
                        <form asp-controller="Account" asp-action="Login" method="post">
                            <br />

                            <div class="form-group">
                                @Html.Label("نام کاربری")
                                <input type="text" name="UserName" class="form-control" required />
                            </div>

                            <br />

                            <div class="form-group">
                                @Html.Label("رمز عبور")
                                <input type="password" name="Password" class="form-control" required />
                            </div>
                            
                            <div class="form-check" style="margin-top:10px">
                                
                                <label asp-for="RememberMe" class="form-check-label">من را به خاطر بسپار</label>
                                <input type="checkbox" asp-for="RememberMe" />
                            </div>

                            <br/>
                            @*returnUrl ارسال*@
                            <input type="hidden" asp-for="@returnUrl" />
                            
                            @*دکمه ارسال*@
                            <button type="submit" class="btn btn-success">ورود</button>
                            
                            <span style="margin-right:20px">
                                <a asp-action="ForgotPassword" asp-controller="Account">
                                    رمز عبور خود را فراموش کرده ام 
                                </a> 
                            </span>

                        </form>
                    </div>

                </div>
            </div>

        </div>

    </div>
</body>
</html>
