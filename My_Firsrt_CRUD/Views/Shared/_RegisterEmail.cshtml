@model string?

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa">
<head>
    <meta charset="utf-8" />
    <title>تأیید ایمیل</title>
    <style>
            body {
                font-family: "Tahoma", Arial, sans-serif;
                background-color: #f4f4f4;
                margin: 0;
                padding: 0;
                direction: rtl;
                text-align: right;
            }

            .email-container {
                max-width: 600px;
                margin: 30px auto;
                background-color: #ffffff;
                border-radius: 8px;
                border: 1px solid #e0e0e0;
                overflow: hidden;
            }

            .email-header {
                background-color: #007bff;
                color: #ffffff;
                padding: 16px 24px;
            }

                .email-header h1 {
                    margin: 0;
                    font-size: 20px;
                    font-weight:bold;
                    text-align:center;
                }

            .email-body {
                padding: 24px;
                color: #333333;
                font-size: 14px;
                line-height: 1.8;
                text-align:right;
            }

                .email-body p {
                    margin: 0 0 12px 0;
                }

            .email-footer {
                padding: 16px 24px;
                font-size: 12px;
                color: #777777;
                border-top: 1px solid #eeeeee;
                text-align: center;
            }

            .btn-confirm {
                display: inline-block;
                margin-top: 16px;
                padding: 10px 24px;
                background-color: #28a745;
                color: #ffffff !important;
                text-decoration: none;
                border-radius: 4px;
                font-weight: bold;
                font-size: 14px;
            }

                .btn-confirm:hover {
                    background-color: #218838;
                }

            .confirm-link {
                word-break: break-all;
                color: #0069d9;
                text-decoration: none;
                font-size: 12px;
            }
    </style>
</head>
<body>

    <div class="email-container">
        <!-- Header -->
        <div class="email-header">
            <h1>تأیید ایمیل حساب کاربری</h1>
        </div>

        <!-- Body -->
        <div class="email-body">
            <p>سلام،</p>
            <p>
                شما در سایت ما ثبت نام کرده اید. برای تکمیل فرآیند ثبت نام و فعال سازی حساب کاربری
                لطفاً ایمیل خود را تأیید کنید.
            </p>

            <p>
                برای تأیید ایمیل، روی دکمه زیر کلیک کنید:
            </p>

            <p>
                <a href="@Model" class="btn-confirm">تأیید ایمیل</a>
            </p>

            <p>
                اگر دکمه بالا برای شما کار نکرد، می توانید با باز کردن لینک زیر در مرورگر خود
                :ایمیل تان را تأیید کنید
            </p>

            <p>
                <a href="@Model" class="confirm-link">@Model</a>
            </p>

            <p style="margin-top: 16px;">
                .اگر شما نبودید ، میتوانید این ایمیل را نادیده بگیرید
            </p>
        </div>

        <!-- Footer -->
        <div class="email-footer">
            <p>
                ،با احترام<br />
                تیم پشتیبانی وبسایت
            </p>
        </div>
    </div>

</body>
</html>